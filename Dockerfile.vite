FROM node:22-alpine

# Install PHP dan ekstensi minimal yang dibutuhkan Laravel Artisan
RUN apk add --no-cache \
    php83 \
    php83-ctype \
    php83-dom \
    php83-fileinfo \
    php83-mbstring \
    php83-openssl \
    php83-pdo \
    php83-session \
    php83-tokenizer \
    php83-xml \
    php83-xmlwriter

# Buat symlink agar bisa dipanggil dengan 'php'
RUN ln -s /usr/bin/php83 /usr/bin/php

WORKDIR /var/www/html